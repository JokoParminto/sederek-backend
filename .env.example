# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jagad-pos
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=jagad_kasir_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=jagad_kasir_refresh_secret_key_change_in_production_2024
